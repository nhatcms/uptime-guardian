DATABASE_URL=sqlite:///./uptime.db
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
CHECK_INTERVAL_MINUTES=5
ALERT_COOLDOWN_MINUTES=10
AUTH_SECRET_KEY=change_me

# Browser origins allowed to call the API (comma-separated).
# Use "*" to allow any origin (e.g. when accessing the dashboard over the LAN by IP).
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Cloudflare Turnstile (server-side bot verification) ---
# Secret key from your Cloudflare Turnstile site. Leave empty to run in dev
# bypass mode (any non-empty token is accepted). Set a real value in production.
TURNSTILE_SECRET_KEY=
TURNSTILE_VERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify

# --- SePay payment gateway (https://developer.sepay.vn/vi) ---
# API key SePay sends on webhook requests (Authorization: Apikey <key>).
SEPAY_API_KEY=
# Shared secret for optional HMAC-SHA256 webhook verification.
SEPAY_WEBHOOK_SECRET=
# Receiving bank account details encoded into the payment QR image.
SEPAY_BANK_CODE=
SEPAY_ACCOUNT_NUMBER=
SEPAY_QR_BASE_URL=https://qr.sepay.vn/img

# Name of the default free plan seeded on first run.
FREE_PLAN_NAME=Free

# --- Google OAuth 2.0 ("Sign in with Google") ---
# Create credentials at https://console.cloud.google.com/apis/credentials
# (OAuth 2.0 Client ID, application type "Web application"). Add the callback
# below to the client's "Authorized redirect URIs". Leave id/secret empty to
# disable the feature (the login routes then return 503).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
# Base URL of the SPA the backend redirects back to after Google sign-in.
FRONTEND_BASE_URL=http://localhost:5173
